---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-16">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <p class="text-sm text-[var(--color-text-dim)]">
        &copy; {year} React Native Vector Icons. MIT License.
      </p>
      <div class="flex items-center gap-4 text-sm text-[var(--color-text-dim)]">
        <a
          href="https://github.com/oblador/react-native-vector-icons"
          class="hover:text-[var(--color-text-muted)] transition-colors duration-150"
        >
          GitHub
        </a>
        <span>&middot;</span>
        <a
          href="https://www.npmjs.com/search?q=%40react-native-vector-icons"
          class="hover:text-[var(--color-text-muted)] transition-colors duration-150"
        >
          npm
        </a>
        <span>&middot;</span>
        <span>Built with Astro</span>
      </div>
    </div>
  </div>
</footer>
